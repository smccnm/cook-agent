# Copy this file to `.env` for local development.
# Default mode: Gemini-enabled when GEMINI_API_KEY is set, otherwise local fallback still works.

# ===== Primary LLM (Gemini) =====
GEMINI_API_KEY=
GEMINI_PLANNING_MODEL=gemini-2.5-flash
GEMINI_GENERATION_MODEL=gemini-2.5-flash

# ===== Optional OpenAI compatibility =====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# ===== Optional search enhancement =====
BING_SEARCH_API_KEY=

# ===== Xiaohongshu login + local MCP binary =====
# XHS_COOKIE and A1 can be filled manually, but the app can also sync them after manual login.
XHS_COOKIE=
A1=
XHS_MCP_BINARY_PATH=vendor/xiaohongshu-mcp/bin/xiaohongshu-mcp-windows-amd64.exe
XHS_LOGIN_BINARY_PATH=vendor/xiaohongshu-mcp/bin/xiaohongshu-login-windows-amd64.exe
XHS_COOKIES_PATH=vendor/xiaohongshu-mcp/cookies.json
XHS_MCP_BASE_URL=http://127.0.0.1:18060

# ===== Backend runtime =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info
LOG_LEVEL=INFO

# ===== Frontend runtime =====
STREAMLIT_SERVER_PORT=8501
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8501

# ===== Retrieval tuning =====
PLAYWRIGHT_TIMEOUT=30000
RANDOM_DELAY_MIN=1.5
RANDOM_DELAY_MAX=4.3
CAPTCHA_DETECTION_ENABLED=true
