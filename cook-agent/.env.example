# Copy this file to `.env` for local development.
# Local no-credential mode works out of the box: leave optional keys empty.

# ===== Optional LLM enhancement =====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# ===== Optional web search enhancement =====
BING_SEARCH_API_KEY=

# ===== Optional Xiaohongshu MCP enhancement (requires both) =====
XHS_COOKIE=
A1=
MCP_SERVICE_PATH=./mcp-server

# ===== Backend runtime =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info
LOG_LEVEL=INFO

# ===== Frontend runtime and service URLs =====
STREAMLIT_SERVER_PORT=8501
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8501

# ===== Optional crawler tuning =====
PLAYWRIGHT_TIMEOUT=30000
RANDOM_DELAY_MIN=1.5
RANDOM_DELAY_MAX=4.3
CAPTCHA_DETECTION_ENABLED=true
