# 美食排菜 Agent 环境变量配置示例
# 复制本文件为 .env，并填入实际值

# ===== OpenAI API 配置 =====
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# ===== Bing Search API 配置 =====
BING_SEARCH_API_KEY=your_bing_search_api_key_here

# ===== MCP 配置（小红书爬虫） =====
# 注意：MCP 策略需要配置以下两个环境变量，否则自动降级
XHS_COOKIE=your_xiaohongshu_cookie_here
A1=your_a1_token_here

# MCP 服务端点（本地 stdio 连接）
# 默认值：git@github.com:smccnm/xiaohongshu-mcp.git
MCP_SERVICE_PATH=./mcp-server

# ===== 后端服务配置 =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info

# ===== 前端配置 =====
STREAMLIT_SERVER_PORT=8501
BACKEND_URL=http://localhost:8000

# ===== 爬虫配置 =====
# Playwright 超时时间（毫秒）
PLAYWRIGHT_TIMEOUT=30000
# 随机延迟范围（秒）
RANDOM_DELAY_MIN=1.5
RANDOM_DELAY_MAX=4.3
# 反爬滑块检测
CAPTCHA_DETECTION_ENABLED=true

# ===== 日志配置 =====
DEBUG=false
LOG_LEVEL=INFO
